# Backend (.NET)
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=regranbill;Username=postgres;Password=<replace-me>
JwtSettings__SecretKey=<replace-with-at-least-32-characters>
JwtSettings__Issuer=ReGranBill
JwtSettings__Audience=ReGranBill
JwtSettings__ExpiryInHours=24
Cors__AllowedOrigins__0=https://localhost:50559
Cors__AllowedOrigins__1=http://localhost:50559
Cors__AllowedOrigins__2=https://127.0.0.1:50559
Cors__AllowedOrigins__3=http://127.0.0.1:50559

# Frontend (Angular proxy)
API_PROXY_TARGET=https://localhost:7081
